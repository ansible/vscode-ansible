{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "noEmit": true,
    "paths": {
      "@wdio/globals": ["../../node_modules/@wdio/globals"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["node", "mocha", "wdio-vscode-service"]
  },
  "include": ["./**/*.ts"]
}
