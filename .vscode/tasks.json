    },
    {
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE v",
          "endsPattern": "^\\s*➜\\s+Local:"
        },
        "fileLocation": "relative",
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        }
      },
      "script": "vite-dev",
      "type": "npm"
    },
    {
      "command": "pnpm run vite-dev",
      "group": "build",
      "isBackground": true,
      "label": "build-then-vite-dev",
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE v",
          "endsPattern": "^\\s*➜\\s+Local:"
        },
        "fileLocation": "relative",
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        }
      },
      "type": "shell"
    },
    {
      "command": "node -e \"try { const pid = require('fs').readFileSync('.vite-dev.pid','utf8').trim(); process.kill(Number(pid)); require('fs').unlinkSync('.vite-dev.pid'); console.log('Vite stopped (pid '+pid+')'); } catch(e) { console.log('No Vite process found'); }\"",
      "label": "kill-vite-dev",
      "presentation": { "reveal": "silent" },
      "type": "shell"
    },
    {
      "command": "pnpm run build:extension",
      "group": "build",
      "label": "build:extension",
      "problemMatcher": [],
      "type": "shell"
    },
    {
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "problemMatcher": [],
      "script": "vite-build",
      "type": "npm"
    }
