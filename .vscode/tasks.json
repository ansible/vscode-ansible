    {
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "label": "Clean",
      "presentation": {
        "panel": "dedicated",
        "reveal": "never"
      },
      "script": "clean",
      "type": "npm"
    },
    {
      "group": {
        "isDefault": true,
        "kind": "build"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE v",
          "endsPattern": "^\\s*➜\\s+Local:"
        },
        "fileLocation": "relative",
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        }
      },
      "script": "vite-dev",
      "type": "npm"
    },
    {
      "label": "build-then-vite-dev",
      "type": "shell",
      "command": "yarn run build:extension && yarn run vite-dev",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE v",
          "endsPattern": "^\\s*➜\\s+Local:"
        },
        "fileLocation": "relative",
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        }
      }
    },
    {
      "label": "kill-vite-dev",
      "type": "shell",
      "command": "kill $(lsof -ti :5173) 2>/dev/null; echo 'Vite stopped'",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build:extension",
      "group": "build",
      "problemMatcher": [],
      "type": "shell",
      "command": "yarn run build:extension"
    },
    {
      "group": {
        "isDefault": true,
