{
  "name": "@ansible/language-server",
  "version": "0.0.1",
  "description": "Ansible language server - provides completion, hover, diagnostics, and semantic tokens for Ansible YAML files",
  "main": "./out/cli.js",
  "types": "./out/server.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "out/"
  ],
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@ansible/developer-services": "workspace:*",
    "@flatten-js/interval-tree": "^2.0.3",
    "antsibull-docs": "^1.1.4",
    "ini": "^6.0.0",
    "lodash": "^4.17.23",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "vscode-uri": "^3.1.0",
    "yaml": "^2.8.3"
  }
}
