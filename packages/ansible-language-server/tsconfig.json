{
  "compilerOptions": {
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "lib",
    "paths": {
      "@src/*": ["./src/*"],
      "@test/*": ["./test/*"]
    },
    "resolveJsonModule": true,
    "target": "ES2022"
  },
  "exclude": ["node_modules", "out", "coverage"],
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts", "test/**/*.ts", "*.ts"]
}
