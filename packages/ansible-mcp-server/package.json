{
  "bin": "dist/cli.js",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "shell-quote": "^1.8.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "description": "Ansible Development Tools MCP server with linting, workspace access, and expert prompts",
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/shell-quote": "^1",
    "@vitest/ui": "^4.1.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0"
  },
  "files": [
    "lib",
    "dist",
    "./src/resources/data/**/*"
  ],
  "keywords": [
    "mcp",
    "ansible",
    "adt",
    "development-tools",
    "ansible-lint",
    "cli",
    "stdio",
    "cursor",
    "ai-assistant"
  ],
  "license": "MIT",
  "main": "dist/cli.cjs",
  "types": "lib/cli.d.ts",
  "module": "lib/cli.js",
  "name": "@ansible/ansible-mcp-server",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rimraf dist lib",
    "compile": "tsc -p . && tsup --silent",
    "dev:stdio": "pnpm exec -- tsx src/cli.ts --stdio",
    "prepack": "pnpm run compile && env NODE_ENV=production tsup --silent",
    "test": "vitest run --project=mcp --coverage.reportsDirectory=../../out/coverage/mcp",
    "test:ade": "vitest run --project=mcp test/adeTools.ts test/adeIntegration.ts",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:integration": "vitest run --project=mcp test/server.ts test/integration.ts test/adeIntegration.ts",
    "test:performance": "vitest run --project=mcp test/performance.ts",
    "test:ui": "vitest --ui --project=mcp",
    "test:unit": "vitest run --project=mcp test/handlers.ts",
    "test:watch": "vitest --project=mcp"
  },
  "type": "module",
  "sideEffects": [
    "dist/*"
  ],
  "version": "0.0.0"
}
