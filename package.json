{
  "name": "ansible-environments",
  "displayName": "Ansible Environments",
  "description": "A VS Code extension for managing Ansible development environments using the Microsoft Python Environments extension API",
  "version": "0.0.1",
  "publisher": "cidrblock",
  "repository": {
    "type": "git",
    "url": "https://github.com/cidrblock/ansible-environments.git"
  },
  "icon": "resources/ansible-icon.png",
  "engines": {
    "vscode": "^1.93.0",
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*"
  ],
  "main": "./out/extension.js",
  "bin": {
    "ansible-environments-mcp": "./packages/mcp-server/out/server.js"
  },
  "extensionDependencies": [
    "ms-python.vscode-python-envs",
    "redhat.vscode-yaml"
  ],
  "contributes": {
    "languages": [
      {
        "aliases": [
          "Ansible",
          "ansible"
        ],
        "configuration": "./ansible-language-configuration.json",
        "extensions": [
          ".ansible.yml",
          ".ansible.yaml"
        ],
        "filenamePatterns": [
          "**/playbooks/*.yml",
          "**/playbooks/*.yaml",
          "**/*playbook*.yml",
          "**/*playbook*.yaml",
          "**/roles/**/main.yml",
          "**/roles/**/main.yaml"
        ],
        "filenames": [
          "site.yml",
          "site.yaml"
        ],
        "firstLine": "# code: language=ansible",
        "id": "ansible"
      },
      {
        "configuration": "./jinja-language-configuration.json",
        "id": "ansible-jinja"
      }
    ],
    "grammars": [
      {
        "language": "ansible",
        "path": "./syntaxes/external/YAML.tmLanguage",
        "scopeName": "source.ansible"
      },
      {
        "language": "ansible-jinja",
        "path": "./syntaxes/external/jinja.tmLanguage.json",
        "scopeName": "source.ansible-jinja"
      },
      {
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/keywords.tmLanguage",
        "scopeName": "injection.ansible.keywords"
      },
      {
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/jinja-extras.tmLanguage",
        "scopeName": "injection.ansible.jinja-extras"
      },
      {
        "embeddedLanguages": {
          "meta.embedded.inline.jinja": "ansible-jinja"
        },
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/jinja-braces.tmLanguage",
        "scopeName": "injection.ansible.jinja-braces"
      },
      {
        "embeddedLanguages": {
          "meta.embedded.inline.jinja": "ansible-jinja"
        },
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/jinja-conditionals.tmLanguage",
        "scopeName": "injection.ansible.jinja-conditionals"
      },
      {
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/jinja-single-quote-escape.tmLanguage",
        "scopeName": "injection.ansible.jinja-single-quote-escape"
      },
      {
        "injectTo": [
          "source.ansible"
        ],
        "path": "./syntaxes/ansible/generated/jinja-double-quote-escape.tmLanguage",
        "scopeName": "injection.ansible.jinja-double-quote-escape"
      }
    ],
    "configurationDefaults": {
      "[ansible]": {
        "editor.autoIndent": "advanced",
        "editor.detectIndentation": true,
        "editor.insertSpaces": true,
        "editor.quickSuggestions": {
          "comments": true,
          "other": true,
          "strings": true
        },
        "editor.tabSize": 2
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          ".ansible-navigator.json",
          "ansible-navigator.json"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-navigator/main/src/ansible_navigator/data/ansible-navigator.json"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": [
          "execution-environment.yml",
          "execution-environment.yaml"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/execution-environment.json"
      },
      {
        "fileMatch": "meta/runtime.yml",
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/meta-runtime.json"
      },
      {
        "fileMatch": [
          ".ansible-navigator.yaml",
          ".ansible-navigator.yml",
          "ansible-navigator.yaml",
          "ansible-navigator.yml"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-navigator/main/src/ansible_navigator/data/ansible-navigator.json"
      },
      {
        "fileMatch": "requirements.yml",
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/requirements.json"
      },
      {
        "fileMatch": "meta/main.yml",
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/meta.json"
      },
      {
        "fileMatch": [
          "playbooks/vars/*.yml",
          "playbooks/vars/*.yaml",
          "vars/*.yml",
          "vars/*.yaml",
          "defaults/*.yml",
          "defaults/*.yaml",
          "host_vars/*.yml",
          "host_vars/*.yaml",
          "group_vars/*.yml",
          "group_vars/*.yaml"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/vars.json"
      },
      {
        "fileMatch": [
          ".ansible-lint",
          ".config/ansible-lint.yml"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible-lint-config.json"
      },
      {
        "fileMatch": "molecule/*/molecule.yml",
        "url": "https://raw.githubusercontent.com/ansible-community/molecule/main/src/molecule/data/molecule.json"
      },
      {
        "fileMatch": "galaxy.yml",
        "url": "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/galaxy.json"
      },
      {
        "fileMatch": [
          "rulebooks/*.yaml",
          "rulebooks/*.yml"
        ],
        "url": "https://raw.githubusercontent.com/ansible/ansible-rulebook/main/ansible_rulebook/schema/ruleset_schema.json"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "ansibleEnvironments",
        "label": "Ansible Environments"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ansible-environments",
          "title": "Ansible Environments",
          "icon": "resources/ansible-icon.svg"
        }
      ]
    },
    "views": {
      "ansible-environments": [
        {
          "id": "ansibleDevToolsEnvManagers",
          "name": "Environment Managers",
          "type": "tree"
        },
        {
          "id": "ansibleDevToolsPackages",
          "name": "Ansible Dev Tools",
          "type": "tree"
        },
        {
          "id": "ansibleDevToolsCollections",
          "name": "Installed Collections",
          "type": "tree"
        },
        {
          "id": "ansibleCollectionSources",
          "name": "Collection Sources",
          "type": "tree"
        },
        {
          "id": "ansibleExecutionEnvironments",
          "name": "Execution Environments",
          "type": "tree"
        },
        {
          "id": "ansibleCreator",
          "name": "Creator",
          "type": "tree"
        },
        {
          "id": "ansiblePlaybooks",
          "name": "Playbooks",
          "type": "tree"
        },
        {
          "id": "ansibleMcpTools",
          "name": "AI Tools",
          "type": "tree",
          "when": "config.ansibleEnvironments.enableAiFeatures"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ansibleDevToolsPackages",
        "contents": "No ansible-dev-tools packages found.\n[Install ansible-dev-tools](command:ansibleDevToolsPackages.install)",
        "when": "!ansibleDevToolsPackages.hasPackages"
      }
    ],
    "commands": [
      {
        "command": "ansibleEnvironments.vault",
        "category": "Ansible",
        "title": "Vault: Encrypt/Decrypt"
      },
      {
        "command": "ansibleDevToolsPackages.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleDevToolsEnvManagers.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleDevToolsEnvManagers.create",
        "title": "Create Environment",
        "icon": "$(add)"
      },
      {
        "command": "ansibleDevTools.selectEnvironment",
        "title": "Select Environment"
      },
      {
        "command": "ansibleDevToolsCollections.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleDevToolsCollections.install",
        "title": "Install Collection",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ansibleDevToolsCollections.refreshGalaxyCache",
        "title": "Refresh Galaxy Cache",
        "icon": "$(database)"
      },
      {
        "command": "ansibleDevToolsCollections.search",
        "title": "Search Plugins",
        "icon": "$(search)"
      },
      {
        "command": "ansibleDevToolsCollections.aiSummary",
        "title": "AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleDevToolsCollections.aiCollectionSummary",
        "title": "Generate AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleDevToolsCollections.showPluginDoc",
        "title": "View Documentation",
        "icon": "$(book)"
      },
      {
        "command": "ansibleDevToolsCollections.aiPluginSummary",
        "title": "Generate AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleDevToolsPackages.install",
        "title": "Install ansible-dev-tools",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ansibleDevToolsPackages.upgrade",
        "title": "Upgrade ansible-dev-tools",
        "icon": "$(arrow-up)"
      },
      {
        "command": "ansibleExecutionEnvironments.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleExecutionEnvironments.aiSummary",
        "title": "AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleExecutionEnvironments.aiEESummary",
        "title": "Generate AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleCreator.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleCreator.aiSummary",
        "title": "AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleCreator.aiEntrySummary",
        "title": "Generate with AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleCreator.openForm",
        "title": "Open Form",
        "icon": "$(window)"
      },
      {
        "command": "ansible-environments.configureCursorMcp",
        "title": "Ansible Environments: Configure Cursor MCP"
      },
      {
        "command": "ansible-environments.showMcpStatus",
        "title": "Ansible Environments: Show MCP Status"
      },
      {
        "command": "ansibleMcpTools.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleMcpTools.useInChat",
        "title": "Use in Chat"
      },
      {
        "command": "ansibleMcpTools.copyPrompt",
        "title": "Copy Prompt",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleMcpTools.configure",
        "title": "Configure MCP",
        "icon": "$(gear)"
      },
      {
        "command": "ansiblePlaybooks.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ansiblePlaybooks.editConfig",
        "title": "Edit Configuration",
        "icon": "$(gear)"
      },
      {
        "command": "ansiblePlaybooks.editDefaults",
        "title": "Edit Default Configuration",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ansiblePlaybooks.run",
        "title": "Run Playbook",
        "icon": "$(play)"
      },
      {
        "command": "ansiblePlaybooks.runWithProgress",
        "title": "Run with Progress Viewer",
        "icon": "$(graph)"
      },
      {
        "command": "ansiblePlaybooks.openPlaybook",
        "title": "Edit Playbook",
        "icon": "$(edit)"
      },
      {
        "command": "ansiblePlaybooks.goToPlay",
        "title": "Go to Play"
      },
      {
        "command": "ansiblePlaybooks.aiSummary",
        "title": "Generate AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleCollectionSources.refresh",
        "title": "Refresh All Sources",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleCollectionSources.refreshSource",
        "title": "Refresh Source",
        "icon": "$(refresh)"
      },
      {
        "command": "ansibleCollectionSources.addSource",
        "title": "Add GitHub Organization",
        "icon": "$(add)"
      },
      {
        "command": "ansibleCollectionSources.install",
        "title": "Install Collection",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ansibleCollectionSources.search",
        "title": "Search Collections",
        "icon": "$(search)"
      },
      {
        "command": "ansibleCollectionSources.searchSource",
        "title": "Search in Source",
        "icon": "$(search)"
      },
      {
        "command": "ansibleCollectionSources.installFromSource",
        "title": "Install from Source",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ansibleCollectionSources.aiSummary",
        "title": "AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleCollectionSources.aiSourceSummary",
        "title": "Generate AI Summary",
        "icon": "$(sparkle)"
      },
      {
        "command": "ansibleEnvironments.selectLlmModel",
        "title": "Select LLM Provider & Model",
        "category": "Ansible Environments",
        "icon": "$(hubot)"
      },
      {
        "command": "ansibleEnvironments.showLlmStatus",
        "title": "Show LLM Status",
        "category": "Ansible Environments",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ansibleEnvironments.vault",
          "when": "editorLangId == ansible",
          "group": "1_ansible"
        }
      ],
      "view/title": [
        {
          "command": "ansibleDevToolsEnvManagers.create",
          "when": "view == ansibleDevToolsEnvManagers",
          "group": "navigation@1"
        },
        {
          "command": "ansibleDevToolsEnvManagers.refresh",
          "when": "view == ansibleDevToolsEnvManagers",
          "group": "navigation@2"
        },
        {
          "command": "ansibleDevToolsPackages.install",
          "when": "view == ansibleDevToolsPackages",
          "group": "navigation@1"
        },
        {
          "command": "ansibleDevToolsPackages.upgrade",
          "when": "view == ansibleDevToolsPackages",
          "group": "navigation@2"
        },
        {
          "command": "ansibleDevToolsPackages.refresh",
          "when": "view == ansibleDevToolsPackages",
          "group": "navigation@3"
        },
        {
          "command": "ansibleDevToolsCollections.search",
          "when": "view == ansibleDevToolsCollections",
          "group": "navigation@1"
        },
        {
          "command": "ansibleDevToolsCollections.refresh",
          "when": "view == ansibleDevToolsCollections",
          "group": "navigation@2"
        },
        {
          "command": "ansibleDevToolsCollections.aiSummary",
          "when": "view == ansibleDevToolsCollections && config.ansibleEnvironments.enableAiFeatures",
          "group": "navigation@3"
        },
        {
          "command": "ansibleExecutionEnvironments.aiSummary",
          "when": "view == ansibleExecutionEnvironments && config.ansibleEnvironments.enableAiFeatures",
          "group": "navigation@1"
        },
        {
          "command": "ansibleExecutionEnvironments.refresh",
          "when": "view == ansibleExecutionEnvironments",
          "group": "navigation@2"
        },
        {
          "command": "ansibleCreator.aiSummary",
          "when": "view == ansibleCreator && config.ansibleEnvironments.enableAiFeatures",
          "group": "navigation@1"
        },
        {
          "command": "ansibleCreator.refresh",
          "when": "view == ansibleCreator",
          "group": "navigation@2"
        },
        {
          "command": "ansibleMcpTools.refresh",
          "when": "view == ansibleMcpTools",
          "group": "navigation@1"
        },
        {
          "command": "ansiblePlaybooks.editDefaults",
          "when": "view == ansiblePlaybooks",
          "group": "navigation@1"
        },
        {
          "command": "ansiblePlaybooks.refresh",
          "when": "view == ansiblePlaybooks",
          "group": "navigation@2"
        },
        {
          "command": "ansibleCollectionSources.search",
          "when": "view == ansibleCollectionSources",
          "group": "navigation@1"
        },
        {
          "command": "ansibleCollectionSources.install",
          "when": "view == ansibleCollectionSources",
          "group": "navigation@2"
        },
        {
          "command": "ansibleCollectionSources.addSource",
          "when": "view == ansibleCollectionSources",
          "group": "navigation@3"
        },
        {
          "command": "ansibleCollectionSources.refresh",
          "when": "view == ansibleCollectionSources",
          "group": "navigation@4"
        },
        {
          "command": "ansibleCollectionSources.aiSummary",
          "when": "view == ansibleCollectionSources && config.ansibleEnvironments.enableAiFeatures",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "ansibleDevToolsCollections.aiCollectionSummary",
          "when": "view == ansibleDevToolsCollections && viewItem == collection && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline"
        },
        {
          "command": "ansibleDevToolsCollections.showPluginDoc",
          "when": "view == ansibleDevToolsCollections && viewItem == plugin",
          "group": "inline@1"
        },
        {
          "command": "ansibleDevToolsCollections.aiPluginSummary",
          "when": "view == ansibleDevToolsCollections && viewItem == plugin && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline@2"
        },
        {
          "command": "ansibleExecutionEnvironments.aiEESummary",
          "when": "view == ansibleExecutionEnvironments && viewItem == executionEnvironment && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline"
        },
        {
          "command": "ansibleCreator.openForm",
          "when": "view == ansibleCreator && viewItem == creatorCommand",
          "group": "inline@1"
        },
        {
          "command": "ansibleCreator.aiEntrySummary",
          "when": "view == ansibleCreator && viewItem == creatorCommand && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline@2"
        },
        {
          "command": "ansiblePlaybooks.run",
          "when": "view == ansiblePlaybooks && viewItem == playbook",
          "group": "inline@1"
        },
        {
          "command": "ansiblePlaybooks.runWithProgress",
          "when": "view == ansiblePlaybooks && viewItem == playbook",
          "group": "inline@2"
        },
        {
          "command": "ansiblePlaybooks.openPlaybook",
          "when": "view == ansiblePlaybooks && viewItem == playbook",
          "group": "inline@3"
        },
        {
          "command": "ansiblePlaybooks.editConfig",
          "when": "view == ansiblePlaybooks && viewItem == playbook",
          "group": "inline@4"
        },
        {
          "command": "ansiblePlaybooks.aiSummary",
          "when": "view == ansiblePlaybooks && viewItem == playbook && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline@5"
        },
        {
          "command": "ansibleMcpTools.copyPrompt",
          "when": "view == ansibleMcpTools && viewItem == mcpTool",
          "group": "inline"
        },
        {
          "command": "ansibleCollectionSources.installFromSource",
          "when": "view == ansibleCollectionSources && viewItem == collectionSource",
          "group": "inline@1"
        },
        {
          "command": "ansibleCollectionSources.searchSource",
          "when": "view == ansibleCollectionSources && viewItem == collectionSource",
          "group": "inline@2"
        },
        {
          "command": "ansibleCollectionSources.refreshSource",
          "when": "view == ansibleCollectionSources && viewItem == collectionSource",
          "group": "inline@3"
        },
        {
          "command": "ansibleCollectionSources.aiSourceSummary",
          "when": "view == ansibleCollectionSources && viewItem == collectionSource && config.ansibleEnvironments.enableAiFeatures",
          "group": "inline@4"
        }
      ]
    },
    "configuration": {
      "title": "Ansible Environments",
      "properties": {
        "ansibleEnvironments.enableAiFeatures": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI enhancements (AI Tools view, sparkle icons, AI prompt buttons)"
        },
        "ansibleEnvironments.pluginDocZoom": {
          "type": "number",
          "default": 100,
          "minimum": 50,
          "maximum": 200,
          "description": "Zoom level for plugin documentation view (50-200%)"
        },
        "ansibleEnvironments.pluginDocTheme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "Follow VS Code theme",
            "Always use light theme",
            "Always use dark theme"
          ],
          "description": "Theme for plugin documentation view"
        },
        "ansibleEnvironments.githubCollectionOrgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "ansible",
            "ansible-collections",
            "redhat-cop"
          ],
          "description": "GitHub organizations to scan for Ansible collections"
        },
        "ansibleEnvironments.llm.chatProvider": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "openllm"
          ],
          "enumDescriptions": [
            "Use VS Code's built-in chat (GitHub Copilot Chat)",
            "Use Open LLM Provider's chat panel"
          ],
          "markdownDescription": "Which chat UI to use for AI features.",
          "scope": "resource",
          "order": 1
        },
        "ansibleEnvironments.llm.configure": {
          "type": "null",
          "markdownDescription": "[Select Provider & Model...](command:ansibleEnvironments.selectLlmModel) · [Show Status](command:ansibleEnvironments.showLlmStatus)",
          "order": 2
        },
        "ansibleEnvironments.llm.provider": {
          "type": "string",
          "default": "",
          "markdownDescription": "*(Advanced)* LLM provider/vendor (e.g., `copilot`, `open-llm`). Leave empty for auto-selection.",
          "scope": "resource",
          "order": 3
        },
        "ansibleEnvironments.llm.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "*(Advanced)* LLM model ID. Leave empty for auto-selection based on provider.",
          "scope": "resource",
          "order": 4
        },
        "ansibleEnvironments.preferredLlmModel": {
          "type": "string",
          "default": "",
          "description": "DEPRECATED: Use 'ansibleEnvironments.llm.provider' and 'ansibleEnvironments.llm.model' instead.",
          "deprecationMessage": "Use 'ansibleEnvironments.llm.provider' and 'ansibleEnvironments.llm.model' instead."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src packages/*/src --ext ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "tsc -p test/integration/tsconfig.json && vscode-test",
    "pretest:ui": "node scripts/install-test-extensions.mjs",
    "test:ui": "wdio run wdio.conf.ts"
  },
  "devDependencies": {
