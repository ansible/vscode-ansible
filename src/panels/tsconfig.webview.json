{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@ansible/ui": ["../../packages/ui/src"],
      "@src/*": ["../*"]
    },
    "types": [],
    "noEmit": true
  },
  "include": [
    "webview-entry.tsx",
    "webview.d.ts",
    "bridges/**/*"
  ]
}
