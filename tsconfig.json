{
  "compilerOptions": {
    // https://github.com/vuejs/tsconfig/blob/main/tsconfig.json
    "allowImportingTsExtensions": true,
    "allowJs": true, // needed by eslint to find .cjs files
    "jsx": "preserve", // required for vue
    "jsxImportSource": "vue", // required for vue
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "noEmit": true,
    "outDir": "lib",
    "paths": {
      "@primeuix/themes/*": ["./node_modules/@primeuix/themes/dist/*"],
      "@root/*": ["./*"],
      "@src/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@webviews/*": ["./webviews/*"]
    }
  },
  "extends": "./tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "tools/**/*.ts",
    "test/**/*.ts",
    "test/**/*.cjs",
    "webviews/**/*.ts",
    "webviews/**/*.vue",
    "*.js",
    "*.ts",
    "*.mts"
  ]
}
