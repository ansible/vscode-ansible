{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "out",
    "rootDir": "src",
    "paths": {
      "@src/*": ["./src/*"]
    },
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".vscode-test", "packages", "src/panels/webview-entry.tsx", "src/panels/bridges", "src/panels/webview.d.ts"],
  "ts-node": {
    "compilerOptions": {
      "types": ["node", "mocha"]
    }
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/language-server" },
    { "path": "packages/mcp-server" }
  ]
}
