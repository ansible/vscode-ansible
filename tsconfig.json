{
  "compilerOptions": {
    "allowJs": true, // needed by eslint to find .cjs files
    "jsx": "preserve", // required for vue
    "jsxImportSource": "vue", // required for vue
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "outDir": "lib",
    "paths": {
      "@primeuix/themes/*": ["./node_modules/@primeuix/themes/dist/*"],
      "@root/*": ["./*"],
      "@src/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@webviews/*": ["./webviews/*"]
    },
    "types": ["@types/mocha", "vscode-webview"]
  },
  "exclude": ["test/wdio/**/*"],
  "extends": "./tsconfig.base.json",
  "include": [
    "*.js",
    "*.mjs",
    "*.mts",
    "*.ts",
    ".*.mjs",
    "src/**/*.ts",
    "test/**/*.cjs",
    "test/**/*.ts",
    "tools/**/*.mts",
    "tools/**/*.ts",
    "webviews/**/*.ts",
    "webviews/**/*.vue"
  ]
}
